{
  "name": "citeguard-mcp",
  "version": "1.0.0",
  "description": "Hallucination-resistant scholarly reference verification system for Claude",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "citeguard-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "citations",
    "scholarly",
    "verification",
    "hallucination-detection",
    "academic",
    "doi",
    "pubmed",
    "crossref"
  ],
  "author": "CiteGuard Contributors",
  "license": "MIT",
  "dependencies": {
    "fastmcp": "^2.0.0",
    "zod": "^3.23.8",
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "node-cache": "^5.1.2",
    "string-similarity": "^4.0.4",
    "fast-xml-parser": "^4.5.1",
    "winston": "^3.17.0",
    "dotenv": "^16.4.7",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/string-similarity": "^4.0.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
